# PitWallAI local simulator config.
# Persistent SQLite so your fantasy team + live FP1/FP2 signals survive restarts.
DATABASE_URL=sqlite+aiosqlite:////Users/whitj17/Development/f1-tactical-intelligence-hive/pitwall_local.sqlite

# Pull real OpenF1 FP1/FP2 for the current weekend (instead of the Monaco mock).
PITWALL_SIM_LIVE=1

# Prices are refreshed from the official F1 Fantasy feed on boot, so treat them
# as verified (transfer recommendations are otherwise gated on this).
PITWALL_PRICES_VERIFIED=1
