# ── Decode (default: free, no API keys) ─────────────────────────────────────
PITWALL_DECODE_BACKEND=rules

# ── LLM (optional — requires explicit budget acknowledgement) ─────────────
# To enable hybrid/llm you MUST set:
#   PITWALL_LLM_BUDGET_ACK=1
#   PITWALL_LLM_MODEL=openai:gpt-4o-mini
#
# Without PITWALL_LLM_BUDGET_ACK=1, the system stays on rules-only even if
# you set hybrid/llm — this prevents accidental spend.

# PITWALL_DECODE_BACKEND=hybrid
# PITWALL_LLM_MODEL=openai:gpt-4o-mini
# PITWALL_LLM_BUDGET_ACK=1

# Hybrid: only escalate when rules confidence is below this (0.0–1.0)
PITWALL_LLM_ESCALATION_THRESHOLD=0.65
PITWALL_LLM_MAX_CONCURRENCY=2

# ── Budget guardrails (worst-case spend caps) ───────────────────────────────
# Monaco rehearsal ≈12 messages; live race can be 50–200+. These defaults
# cap a full race at ~$0.50/session and ~$2/day estimated.

PITWALL_LLM_MAX_CALLS_PER_SESSION=12
PITWALL_LLM_MAX_CALLS_PER_MINUTE=4
PITWALL_LLM_MAX_CALLS_PER_HOUR=25
PITWALL_LLM_MAX_CALLS_PER_DAY=75
PITWALL_LLM_MAX_USD_PER_SESSION=0.50
PITWALL_LLM_MAX_USD_PER_DAY=2.00
PITWALL_LLM_COST_PER_CALL_USD=0.02
PITWALL_LLM_BUDGET_COOLDOWN_SECONDS=300

# ── Performance ───────────────────────────────────────────────────────────
PITWALL_DECODE_DEDUP_TTL=30
PITWALL_EMBEDDING_CACHE_SIZE=512

# ── Security / networking ───────────────────────────────────────────────────
PITWALL_BIND_HOST=127.0.0.1
PITWALL_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
PITWALL_WS_MAX_CONNECTIONS=32
PITWALL_LOG_TRANSCRIPTS=false
