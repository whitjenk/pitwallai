# ── Decode (default: free, no API keys) ─────────────────────────────────────
PITWALL_DECODE_BACKEND=rules

# ── LLM (optional — requires explicit budget acknowledgement) ─────────────
# Default provider: Vertex AI Gemini (Application Default Credentials).
# Set GOOGLE_CLOUD_PROJECT and authenticate: gcloud auth application-default login
#
# PITWALL_DECODE_BACKEND=hybrid
# PITWALL_LLM_PROVIDER=gemini
# PITWALL_LLM_MODEL=gemini-2.0-flash
# PITWALL_LLM_USE_VERTEX=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# GOOGLE_CLOUD_LOCATION=us-central1
# PITWALL_LLM_BUDGET_ACK=1
#
# Google AI Studio BYOK (non-Vertex):
# PITWALL_LLM_USE_VERTEX=false
# PITWALL_GOOGLE_API_KEY=your-key
#
# Other providers (same prompt/schema — model is just a parameter):
# PITWALL_LLM_PROVIDER=openai
# PITWALL_OPENAI_API_KEY=sk-...
# PITWALL_LLM_MODEL=gpt-4o-mini
#
# PITWALL_LLM_PROVIDER=claude
# PITWALL_ANTHROPIC_API_KEY=sk-ant-...
# PITWALL_LLM_MODEL=claude-3-5-sonnet-latest
#
# PITWALL_LLM_PROVIDER=ollama
# PITWALL_OLLAMA_BASE_URL=http://localhost:11434/v1
# PITWALL_LLM_MODEL=llama3.2

# Hybrid: only escalate when rules confidence is below this (0.0–1.0)
PITWALL_LLM_ESCALATION_THRESHOLD=0.65
PITWALL_LLM_MAX_CONCURRENCY=2

# ── Budget guardrails (worst-case spend caps) ───────────────────────────────
PITWALL_LLM_MAX_CALLS_PER_SESSION=8
PITWALL_LLM_MAX_CALLS_PER_MINUTE=4
PITWALL_LLM_MAX_CALLS_PER_HOUR=20
PITWALL_LLM_MAX_CALLS_PER_DAY=50
PITWALL_LLM_MAX_USD_PER_SESSION=0.30
PITWALL_LLM_MAX_USD_PER_DAY=1.00
PITWALL_LLM_COST_PER_CALL_USD=0.02
PITWALL_LLM_BUDGET_COOLDOWN_SECONDS=300

# ── Performance ───────────────────────────────────────────────────────────
PITWALL_DECODE_DEDUP_TTL=30
PITWALL_EMBEDDING_CACHE_SIZE=512

# ── Security / networking ───────────────────────────────────────────────────
PITWALL_BIND_HOST=127.0.0.1
PITWALL_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
PITWALL_WS_MAX_CONNECTIONS=32
PITWALL_LOG_TRANSCRIPTS=false

# Structured pick explanation cards in Saturday WhatsApp broadcasts (Agent 3)
EXPLANATION_CARDS_ENABLED=true

# ── Fantasy picks pipeline ───────────────────────────────────────────────────
# Legacy poll (quali broadcast uses APScheduler race calendar instead)
# PITWALL_PICKS_AUTO=false
# PITWALL_PICKS_INTERVAL_SECONDS=1800
# PITWALL_RACE_YEAR=2026
# Force a circuit when off-calendar or in rehearsal: monaco, monza, etc.
# PITWALL_CIRCUIT_KEY=monaco
# Race calendar APScheduler uses DATABASE_URL for persistent job store (apscheduler_jobs table)

# ── Database (Railway auto-injects DATABASE_URL in production) ───────────────
# DATABASE_URL=postgresql://user:pass@host:5432/pitwallai

# ── WhatsApp Cloud API ──────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Choose any secret string — must match Meta webhook verify token field
WEBHOOK_VERIFY_TOKEN=
# Meta App Secret — required for POST /webhook (X-Hub-Signature-256)
WHATSAPP_APP_SECRET=
# Public display number for /results CTA (E.164 or friendly label)
WHATSAPP_DISPLAY_NUMBER=
# Local dev only: skip webhook HMAC verification (never in production / mode=live)
# PITWALL_DEV_ONLY_SKIP_WEBHOOK_SIGNATURE=1
# PITWALL_WEBHOOK_SKIP_SIGNATURE=1   # legacy alias

# Vision screenshot caps (per-phone hourly / global daily)
# PITWALL_VISION_MAX_PER_PHONE_HOUR=2
# PITWALL_VISION_MAX_GLOBAL_DAY=500

# Global monthly spend kill-switch (LLM + vision + WhatsApp in spend_events table)
# PITWALL_MONTHLY_SPEND_CAP_USD=75
# PITWALL_SPEND_WARN_PCT=80
# PITWALL_WHATSAPP_COST_PER_MESSAGE_USD=0.008
# PITWALL_VISION_COST_PER_CALL_USD=0.001

# Public homepage subscriber-reveal threshold (count is hidden below this).
# PITWALL_SUBSCRIBER_REVEAL_THRESHOLD=250

# Onboarding-funnel alert threshold + minimum sample size before alerting.
# PITWALL_ONBOARDING_THRESHOLD=0.50
# PITWALL_ONBOARDING_MIN_SAMPLE=10

# ── Picks REST API ───────────────────────────────────────────────────────────
# Required in production: all /api/picks routes require this key.
# Pass via X-PitWall-API-Key (or Authorization: Bearer <key>).
PITWALL_PICKS_API_KEY=
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Feature flags (Bet 1 is the only sanctioned surface; rest default OFF) ──
# Bet 1: Explanation cards on Saturday picks + SHARE [driver] forwardable card.
# Everything below is OFF until subscriber data justifies turning it on.
# PITWALL_CHIPS_ENABLED=0
# PITWALL_CONSTRUCTOR_STRATEGY_ENABLED=0
# PITWALL_COUNTERFACTUAL_ENABLED=0
# PITWALL_SEASON_RECAP_ENABLED=0
# PITWALL_BUDGET_TRANSFERS_ENABLED=0
# PITWALL_COMMUNITY_AGGREGATE_ENABLED=0
# Screenshot-based onboarding: send a screenshot of your F1 Fantasy team
# instead of typing driver codes. Defaults ON.
PITWALL_SCREENSHOT_ONBOARDING_ENABLED=1
EXPLANATION_CARDS_ENABLED=true
